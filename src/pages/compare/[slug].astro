---
import FaqList from "../../components/FaqList.astro";
import PageHero from "../../components/PageHero.astro";
import SectionHead from "../../components/SectionHead.astro";
import { comparisons, defaultScenario, platforms, VERIFIED_AT } from "../../data/pricing";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { calculateStack } from "../../lib/calculate";

export function getStaticPaths() {
  return comparisons.flatMap((comparison) => {
    const left = platforms.find((platform) => platform.id === comparison.left);
    const right = platforms.find((platform) => platform.id === comparison.right);
    if (left === undefined || right === undefined) return [];
    return [{ params: { slug: comparison.slug }, props: { comparison, left, right } }];
  });
}

const { comparison, left, right } = Astro.props;
const leftEstimate = calculateStack({ ...defaultScenario, platformId: left.id });
const rightEstimate = calculateStack({ ...defaultScenario, platformId: right.id });
const tied = Math.abs(leftEstimate.monthly - rightEstimate.monthly) < 0.01;
const lower = leftEstimate.monthly <= rightEstimate.monthly ? left : right;
const difference = Math.abs(leftEstimate.monthly - rightEstimate.monthly);
const faqs = [
  {
    question: `Which is cheaper, ${left.name} or ${right.name}?`,
    answer: tied
      ? `Under this 10,000-minute public-price scenario, ${left.name} and ${right.name} tie at about $${leftEstimate.monthly.toLocaleString("en-US")} per month. Your model, carrier, usage, and enterprise terms can break the tie.`
      : `Under this 10,000-minute public-price scenario, ${lower.name} is lower by about $${difference.toLocaleString("en-US")} per month. Your model, carrier, usage, and enterprise terms can reverse the result.`,
  },
  {
    question: "What does the example include?",
    answer:
      "Ten thousand outbound US minutes, five-minute average calls, Deepgram Nova-3, GPT-5 mini, integrated Cartesia-class TTS, Twilio local outbound, and no recording. Bundled platforms ignore separate speech and model charges.",
  },
  {
    question: "Which platform should I choose?",
    answer: `${left.name} is strongest for ${left.bestFor.toLowerCase()} ${right.name} is strongest for ${right.bestFor.toLowerCase()} Price is one constraint; control, deployment model, latency, compliance, and operational capacity also matter.`,
  },
] as const;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: comparison.title,
  description: comparison.description,
  dateModified: VERIFIED_AT,
  author: { "@type": "Organization", name: "OSS.codes" },
};
---

<BaseLayout
  title={`${comparison.title}: Pricing and Cost Comparison`}
  description={`${comparison.description} Includes a normalized 10,000-minute estimate, primary sources, and decision guidance.`}
  structuredData={structuredData}
>
  <PageHero
    eyebrow="platform comparison"
    title={`${left.name} vs ${right.name}.`}
    description={comparison.description}
    parent={{ href: "/compare/", label: "compare" }}
  >
    <div class="cluster hero-actions">
      <a class="button button-primary" href={`/calculator/?a=${left.id}&b=${right.id}`}>model your usage →</a>
      <a class="button" href="/methodology/">inspect assumptions</a>
    </div>
  </PageHero>

  <section class="section">
    <SectionHead
      label="10K minute result"
      title={tied ? `${left.name} and ${right.name} tie in the baseline` : `${lower.name} is lower in the baseline`}
      description="This is a normalized public-list-price model, not an enterprise quote. It exists to reveal component differences, not predict your exact invoice."
    />
    <div class="data-strip">
      <div class:list={["data-cell", { best: tied || left.id === lower.id }]}>
        <span class="data-label">{left.name}</span>
        <strong class="data-value">${leftEstimate.monthly.toLocaleString("en-US")}</strong>
        <span class="cost-meta">${leftEstimate.perMinute.toFixed(4)}/min</span>
      </div>
      <div class:list={["data-cell", { best: tied || right.id === lower.id }]}>
        <span class="data-label">{right.name}</span>
        <strong class="data-value">${rightEstimate.monthly.toLocaleString("en-US")}</strong>
        <span class="cost-meta">${rightEstimate.perMinute.toFixed(4)}/min</span>
      </div>
      <div class="data-cell">
        <span class="data-label">Monthly delta</span>
        <strong class="data-value">${difference.toLocaleString("en-US")}</strong>
        <span class="cost-meta">before negotiated discounts</span>
      </div>
      <div class="data-cell">
        <span class="data-label">Snapshot</span>
        <strong class="data-value">{VERIFIED_AT}</strong>
        <span class="cost-meta">primary sources linked below</span>
      </div>
    </div>
  </section>

  <section class="section">
    <SectionHead
      label="pricing structure"
      title="Why the advertised numbers differ"
      description="The key question is whether the headline minute is a platform layer or a complete agent stack."
    />
    <table class="simple-table">
      <thead>
        <tr><th>Dimension</th><th>{left.name}</th><th>{right.name}</th></tr>
      </thead>
      <tbody>
        <tr><td>Published structure</td><td data-label={left.name}>{left.summary}</td><td data-label={right.name}>{right.summary}</td></tr>
        <tr><td>STT / LLM / TTS</td><td data-label={left.name}>{left.bundledModels ? "Bundled" : "Separate"}</td><td data-label={right.name}>{right.bundledModels ? "Bundled" : "Separate"}</td></tr>
        <tr><td>Monthly base</td><td data-label={left.name}>${left.monthlyBase}</td><td data-label={right.name}>${right.monthlyBase}</td></tr>
        <tr><td>Best fit</td><td data-label={left.name}>{left.bestFor}</td><td data-label={right.name}>{right.bestFor}</td></tr>
      </tbody>
    </table>
  </section>

  <section class="section">
    <SectionHead
      label="decision"
      title="Choose for the operating model"
      description="The lowest modeled bill is useful, but ownership and deployment fit determine whether that bill stays low in production."
    />
    <div class="prose">
      <h3>Choose {left.name} when</h3>
      <p>{left.bestFor}</p>
      <h3>Choose {right.name} when</h3>
      <p>{right.bestFor}</p>
      <p>
        Before signing a contract, rerun the calculator with your actual traffic direction,
        average handle time, recording policy, model tier, and peak concurrency. Then request a
        provider quote at the same usage profile.
      </p>
    </div>
  </section>

  <section class="section">
    <SectionHead
      label="sources"
      title="Check both current pricing pages"
      description={`Public prices checked ${VERIFIED_AT}.`}
    />
    <ul class="source-list">
      <li><a class="source-badge" href={left.sourceUrl}>{left.name} pricing ↗</a></li>
      <li><a class="source-badge" href={right.sourceUrl}>{right.name} pricing ↗</a></li>
    </ul>
  </section>

  <section class="section">
    <SectionHead
      label="FAQ"
      title={`${comparison.title} questions`}
      description="Short answers for the common decision boundaries."
    />
    <FaqList items={faqs} />
  </section>
</BaseLayout>
