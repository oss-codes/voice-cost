---
import PageHero from "../../components/PageHero.astro";
import SectionHead from "../../components/SectionHead.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  defaultAsteriskConfig,
  generateAsteriskConfig,
} from "../../lib/asterisk-config";

const initialBundle = generateAsteriskConfig(defaultAsteriskConfig);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Asterisk Voice AI Configuration Generator",
  url: "https://voice.oss.codes/tools/asterisk-config-generator/",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Any",
  description:
    "Generate a safe Asterisk PJSIP, dialplan, RTP, HTTP, ARI, and external-media configuration for Voice AI calls.",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
};
---

<BaseLayout
  title="Asterisk Voice AI Configuration Generator"
  description="Generate Asterisk PJSIP, dialplan, RTP, HTTP, ARI, NAT, and external-media configuration for a Voice AI call, with safe credential placeholders."
  structuredData={structuredData}
>
  <PageHero
    eyebrow="Asterisk config generator"
    title="Build the files between your SIP trunk and Voice AI runtime."
    description="Enter the trunk, network, dialplan, and media details. The generator creates 6 inspectable files and never asks for a SIP or ARI password."
    parent={{ href: "/tools/", label: "tools" }}
  >
    <div class="cluster hero-actions">
      <a class="button button-primary" href="#generator">Generate configuration</a>
      <a class="button" href="/guides/asterisk-voice-ai-configuration/">Read the deployment guide</a>
    </div>
  </PageHero>

  <section class="section" id="generator">
    <form class="builder-shell" data-asterisk-generator autocomplete="off">
      <div class="builder-controls">
        <div class="notice">
          <strong>secret-safe</strong>
          <span>Passwords are not collected or placed in the URL. Generated files keep explicit placeholders.</span>
        </div>
        <fieldset class="field-group">
          <legend>Carrier and identity</legend>
          <label class="field">
            <span class="field-label">SIP host</span>
            <input name="sipHost" value={defaultAsteriskConfig.sipHost} maxlength="120" spellcheck="false" />
          </label>
          <label class="field">
            <span class="field-label">Account ID</span>
            <input name="accountId" value={defaultAsteriskConfig.accountId} maxlength="80" spellcheck="false" />
          </label>
          <label class="field">
            <span class="field-label">SIP username</span>
            <input name="sipUsername" value={defaultAsteriskConfig.sipUsername} maxlength="80" spellcheck="false" />
          </label>
          <label class="field">
            <span class="field-label">Registration contact user</span>
            <input name="contactUser" value={defaultAsteriskConfig.contactUser} maxlength="80" spellcheck="false" />
          </label>
          <label class="field">
            <span class="field-label">Owned caller ID</span>
            <input name="callerId" type="tel" value={defaultAsteriskConfig.callerId} maxlength="24" spellcheck="false" />
          </label>
        </fieldset>

        <fieldset class="field-group">
          <legend>Network and media</legend>
          <label class="field">
            <span class="field-label">Public IP or hostname</span>
            <input name="publicAddress" value={defaultAsteriskConfig.publicAddress} maxlength="120" spellcheck="false" />
          </label>
          <label class="field">
            <span class="field-label">Private network CIDR</span>
            <input name="privateCidr" value={defaultAsteriskConfig.privateCidr} maxlength="64" spellcheck="false" />
          </label>
          <label class="field">
            <span class="field-label">Carrier signaling CIDR</span>
            <input name="carrierCidr" value={defaultAsteriskConfig.carrierCidr} maxlength="64" spellcheck="false" />
          </label>
          <div class="compact-fields">
            <label class="field">
              <span class="field-label">SIP port</span>
              <input name="sipPort" type="number" min="1" max="65535" value={defaultAsteriskConfig.sipPort} inputmode="numeric" />
            </label>
            <label class="field">
              <span class="field-label">RTP start</span>
              <input name="rtpStart" type="number" min="1024" max="65534" value={defaultAsteriskConfig.rtpStart} inputmode="numeric" />
            </label>
            <label class="field">
              <span class="field-label">RTP end</span>
              <input name="rtpEnd" type="number" min="1025" max="65535" value={defaultAsteriskConfig.rtpEnd} inputmode="numeric" />
            </label>
          </div>
          <label class="field">
            <span class="field-label">Codec</span>
            <select name="codec">
              <option value="ulaw">ulaw / G.711 μ-law</option>
              <option value="alaw">alaw / G.711 A-law</option>
              <option value="g722">G.722 wideband</option>
            </select>
          </label>
          <label class="field">
            <span class="field-label">External media transport</span>
            <select name="mediaTransport">
              <option value="rtp">RTP over UDP</option>
              <option value="websocket">chan_websocket</option>
            </select>
          </label>
        </fieldset>

        <fieldset class="field-group">
          <legend>Dialplan and ARI</legend>
          <label class="field">
            <span class="field-label">Stasis app name</span>
            <input name="appName" value={defaultAsteriskConfig.appName} maxlength="64" spellcheck="false" />
          </label>
          <label class="field">
            <span class="field-label">ARI username</span>
            <input name="ariUsername" value={defaultAsteriskConfig.ariUsername} maxlength="64" spellcheck="false" />
          </label>
          <label class="field">
            <span class="field-label">Inbound extension</span>
            <input name="inboundExtension" value={defaultAsteriskConfig.inboundExtension} maxlength="64" spellcheck="false" />
          </label>
        </fieldset>
        <p class="form-error" data-form-error role="alert" aria-live="assertive" hidden></p>
        <div class="calc-actions">
          <button class="button button-primary" type="button" data-download-bundle>Download all files</button>
          <button class="button" type="reset">Reset configuration</button>
        </div>
        <p class="field-note">
          The URL stores only codec, transport, and port choices. It does not store carrier IDs,
          network addresses, caller ID, or usernames.
        </p>
      </div>

      <div class="builder-output" aria-live="polite">
        <div class="output-heading">
          <div>
            <span class="data-label">generated bundle</span>
            <h2>Review every line before production</h2>
          </div>
          <span class="output-status" data-output-status>6 files ready</span>
        </div>
        {
          Object.entries(initialBundle).map(([filename, code]) => (
            <article class="config-block dynamic-config" data-config-file={filename}>
              <header>
                <div>
                  <span class="data-label">generated file</span>
                  <strong>{filename}</strong>
                </div>
                <div class="config-actions">
                  <button type="button" data-copy-file={filename}>Copy file</button>
                  <button type="button" data-download-file={filename}>Download</button>
                </div>
              </header>
              <pre><code data-config-code={filename}>{code}</code></pre>
            </article>
          ))
        }
      </div>
    </form>
  </section>

  <section class="section">
    <SectionHead
      label="before restart"
      title="Treat generated files as a checked starting point"
      description="Carrier authentication, inbound DID routing, firewall rules, TLS, SRTP, codec negotiation, and module availability still depend on your provider and Asterisk build."
    />
    <div class="guide-facts">
      <div>
        <span class="data-label">credentials</span>
        <strong>Add secrets on the server</strong>
        <p>Replace both password placeholders outside source control.</p>
      </div>
      <div>
        <span class="data-label">network</span>
        <strong>Open the exact RTP range</strong>
        <p>Match the host firewall, upstream NAT, and <code>rtp.conf</code>.</p>
      </div>
      <div>
        <span class="data-label">verification</span>
        <strong>Trace one real call</strong>
        <p>Confirm registration, dialplan entry, ARI events, SDP, and two-way audio.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { z } from "zod";

  import {
    generateAsteriskConfig,
    serializeAsteriskBundle,
    type AsteriskConfigBundle,
  } from "../../lib/asterisk-config";

  const form = document.querySelector("[data-asterisk-generator]");
  const token = z.string().trim().min(1).max(120).regex(/^[A-Za-z0-9._:+/@-]+$/);
  const cidr = z.string().trim().min(3).max(64).regex(/^[A-Fa-f0-9:.]+\/[0-9]{1,3}$/);
  const name = z.string().trim().min(1).max(64).regex(/^[A-Za-z0-9_.+-]+$/);
  const ConfigSchema = z
    .object({
      sipHost: token,
      accountId: token,
      sipUsername: token,
      contactUser: name,
      publicAddress: token,
      privateCidr: cidr,
      carrierCidr: cidr,
      sipPort: z.number().int().min(1).max(65_535),
      rtpStart: z.number().int().min(1_024).max(65_534),
      rtpEnd: z.number().int().min(1_025).max(65_535),
      codec: z.enum(["ulaw", "alaw", "g722"]),
      appName: name,
      ariUsername: name,
      inboundExtension: name,
      callerId: z.string().trim().min(3).max(24).regex(/^\+?[0-9]+$/),
      mediaTransport: z.enum(["rtp", "websocket"]),
    })
    .refine((value) => value.rtpEnd > value.rtpStart, {
      message: "RTP end must be greater than RTP start.",
    });

  if (form instanceof HTMLFormElement) {
    let currentBundle: AsteriskConfigBundle | undefined;
    const textValue = (fieldName: string) => {
      const field = form.elements.namedItem(fieldName);
      return field instanceof HTMLInputElement || field instanceof HTMLSelectElement
        ? field.value
        : "";
    };
    const numberValue = (fieldName: string) => Number(textValue(fieldName));
    const error = form.querySelector("[data-form-error]");
    const status = form.querySelector("[data-output-status]");
    const safeNames = ["sipPort", "rtpStart", "rtpEnd", "codec", "mediaTransport"] as const;

    const downloadText = (filename: string, content: string) => {
      const url = URL.createObjectURL(new Blob([content], { type: "text/plain;charset=utf-8" }));
      const anchor = document.createElement("a");
      anchor.href = url;
      anchor.download = filename;
      anchor.click();
      URL.revokeObjectURL(url);
    };

    const updateUrl = () => {
      const params = new URLSearchParams();
      for (const fieldName of safeNames) params.set(fieldName, textValue(fieldName));
      window.history.replaceState(null, "", `${window.location.pathname}?${params.toString()}`);
    };

    const render = () => {
      const parsed = ConfigSchema.safeParse({
        sipHost: textValue("sipHost"),
        accountId: textValue("accountId"),
        sipUsername: textValue("sipUsername"),
        contactUser: textValue("contactUser"),
        publicAddress: textValue("publicAddress"),
        privateCidr: textValue("privateCidr"),
        carrierCidr: textValue("carrierCidr"),
        sipPort: numberValue("sipPort"),
        rtpStart: numberValue("rtpStart"),
        rtpEnd: numberValue("rtpEnd"),
        codec: textValue("codec"),
        appName: textValue("appName"),
        ariUsername: textValue("ariUsername"),
        inboundExtension: textValue("inboundExtension"),
        callerId: textValue("callerId"),
        mediaTransport: textValue("mediaTransport"),
      });

      if (!parsed.success) {
        if (error instanceof HTMLElement) {
          error.textContent =
            parsed.error.issues[0]?.message === "RTP end must be greater than RTP start."
              ? "RTP end must be greater than RTP start."
              : "Use valid host, CIDR, port, identifier, and caller ID values without spaces or line breaks.";
          error.hidden = false;
        }
        if (status instanceof HTMLElement) status.textContent = "Fix inputs to regenerate";
        return;
      }

      if (error instanceof HTMLElement) {
        error.textContent = "";
        error.hidden = true;
      }
      currentBundle = generateAsteriskConfig(parsed.data);
      for (const [filename, code] of Object.entries(currentBundle)) {
        const output = form.querySelector(`[data-config-code="${filename}"]`);
        if (output instanceof HTMLElement) output.textContent = code;
      }
      if (status instanceof HTMLElement) status.textContent = "6 files ready";
      updateUrl();
    };

    const setInitialSafeState = () => {
      const params = new URLSearchParams(window.location.search);
      for (const fieldName of safeNames) {
        const candidate = params.get(fieldName);
        const field = form.elements.namedItem(fieldName);
        if (candidate === null) continue;
        if (field instanceof HTMLInputElement) field.value = candidate;
        if (
          field instanceof HTMLSelectElement &&
          Array.from(field.options).some((option) => option.value === candidate)
        ) {
          field.value = candidate;
        }
      }
    };

    form.addEventListener("input", render);
    form.addEventListener("change", render);
    form.addEventListener("reset", () => window.setTimeout(render));
    form.addEventListener("click", async (event) => {
      const target = event.target;
      if (!(target instanceof HTMLButtonElement)) return;
      const copyFilename = target.dataset["copyFile"];
      const downloadFilename = target.dataset["downloadFile"];
      if (copyFilename && currentBundle) {
        await navigator.clipboard.writeText(currentBundle[copyFilename as keyof AsteriskConfigBundle]);
        target.textContent = "Copied";
        window.setTimeout(() => {
          target.textContent = "Copy file";
        }, 1_500);
      }
      if (downloadFilename && currentBundle) {
        downloadText(
          downloadFilename,
          currentBundle[downloadFilename as keyof AsteriskConfigBundle],
        );
      }
      if (target.hasAttribute("data-download-bundle") && currentBundle) {
        downloadText("asterisk-voice-ai-config.txt", serializeAsteriskBundle(currentBundle));
      }
    });

    setInitialSafeState();
    render();
  }
</script>
