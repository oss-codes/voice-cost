---
import FaqList from "../../components/FaqList.astro";
import PageHero from "../../components/PageHero.astro";
import SectionHead from "../../components/SectionHead.astro";
import { defaultScenario, platforms, VERIFIED_AT } from "../../data/pricing";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { calculateStack } from "../../lib/calculate";

export function getStaticPaths() {
  return platforms.map((platform) => ({
    params: { slug: platform.slug },
    props: { platform },
  }));
}

const { platform } = Astro.props;
const estimate = calculateStack({ ...defaultScenario, platformId: platform.id });
const faqs = [
  {
    question: `How much does ${platform.name} cost per minute?`,
    answer: `${platform.summary} A complete production call can also include carrier, recording, observability, compliance, and engineering costs.`,
  },
  {
    question: `What is ${platform.name} best for?`,
    answer: platform.bestFor,
  },
  {
    question: "Is this an official quote?",
    answer: `No. This is an independent public-price snapshot verified ${VERIFIED_AT}. Follow the primary pricing source before making a purchasing decision.`,
  },
] as const;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: `${platform.name} pricing explained`,
  description: platform.summary,
  dateModified: VERIFIED_AT,
  author: { "@type": "Organization", name: "OSS.codes" },
};
---

<BaseLayout
  title={`${platform.name} Pricing Explained`}
  description={`${platform.name} Voice AI pricing: what the advertised rate includes, a 10,000-minute cost example, source links, and key assumptions.`}
  structuredData={structuredData}
>
  <PageHero
    eyebrow="provider pricing"
    title={`${platform.name} pricing, explained.`}
    description={platform.summary}
    parent={{ href: "/pricing/", label: "pricing" }}
  >
    <div class="cluster hero-actions">
      <a class="button button-primary" href={`/calculator/?a=${platform.id}`}>calculate your usage →</a>
      <a class="button" href={platform.sourceUrl}>official pricing ↗</a>
    </div>
  </PageHero>

  <section class="section">
    <SectionHead
      label="10K minute model"
      title="A like-for-like starting point"
      description="Outbound US calls with Deepgram Nova-3, GPT-5 mini, integrated Cartesia-class TTS, and no recording. Bundled providers ignore separate model choices."
    />
    <div class="data-strip">
      <div class="data-cell best">
        <span class="data-label">Monthly estimate</span>
        <strong class="data-value">${estimate.monthly.toLocaleString("en-US")}</strong>
      </div>
      <div class="data-cell">
        <span class="data-label">Effective minute</span>
        <strong class="data-value">${estimate.perMinute.toFixed(4)}</strong>
      </div>
      <div class="data-cell">
        <span class="data-label">Five-minute call</span>
        <strong class="data-value">${estimate.perCall.toFixed(2)}</strong>
      </div>
      <div class="data-cell">
        <span class="data-label">Models</span>
        <strong class="data-value">{platform.bundledModels ? "included" : "separate"}</strong>
      </div>
    </div>
  </section>

  <section class="section">
    <SectionHead
      label="fit"
      title="When this pricing model makes sense"
      description={platform.bestFor}
    />
    <div class="prose">
      <p>
        The most important distinction is whether <strong>{platform.name}</strong> sells a complete
        agent minute or one layer of the stack. {platform.bundledModels
          ? "Its published rate bundles the speech and intelligence layers, which makes early forecasting simpler."
          : "Its published rate is only part of the total, which gives you more provider control but requires component-level forecasting."}
      </p>
      <p>
        Carrier charges are still modeled separately because phone rates change by direction,
        destination, number type, and volume. Recording, storage, compliance, analytics, and human
        transfer time can also create material deltas.
      </p>
    </div>
  </section>

  <section class="section">
    <SectionHead
      label="source"
      title="Verify the current rate"
      description={`Snapshot checked ${VERIFIED_AT}. Provider pages can change without notice.`}
    />
    <a class="source-badge" href={platform.sourceUrl}>{platform.sourceUrl} ↗</a>
  </section>

  <section class="section">
    <SectionHead
      label="FAQ"
      title={`${platform.name} pricing questions`}
      description="The short version of the assumptions and boundaries behind this profile."
    />
    <FaqList items={faqs} />
  </section>
</BaseLayout>
