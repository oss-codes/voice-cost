---
import {
  carriers,
  defaultScenario,
  llmModels,
  platforms,
  sttModels,
  ttsModels,
} from "../data/pricing";
import { calculateStack } from "../lib/calculate";

const selectedStt = sttModels.find((item) => item.id === defaultScenario.sttId);
const selectedLlm = llmModels.find((item) => item.id === defaultScenario.llmId);
const selectedTts = ttsModels.find((item) => item.id === defaultScenario.ttsId);
const selectedCarrier = carriers.find((item) => item.id === defaultScenario.carrierId);

if (!selectedStt || !selectedLlm || !selectedTts || !selectedCarrier) {
  throw new Error("The comparison baseline references an unknown pricing item.");
}

const modelRate = selectedStt.perMinute + selectedLlm.perMinute + selectedTts.perMinute;
const rows = platforms.filter((platform) => platform.id !== "self-hosted").map((platform) => ({
  ...platform,
  estimate: calculateStack({ ...defaultScenario, platformId: platform.id }),
  modelRate: platform.bundledModels ? 0 : modelRate,
}));
---

<div class="cost-model" data-cost-model>
  <div class="cost-control">
    <label for="comparison-minutes">Monthly connected minutes</label>
    <input
      id="comparison-minutes"
      name="comparison-minutes"
      type="number"
      min="100"
      max="10000000"
      step="100"
      value={defaultScenario.monthlyMinutes}
    />
    <p>
      Baseline: Nova-3, GPT-5 mini, a $0.015/min voice, US outbound Twilio, and no
      recording. Published rates checked before enterprise discounts.
    </p>
  </div>

  <div class="cost-caption" aria-live="polite">
    <span>Normalized workload</span>
    <strong data-volume-label>10,000 minutes</strong>
  </div>

  <div class="cost-table" role="table" aria-label="Normalized voice AI platform cost">
    <div class="cost-head" role="row">
      <span role="columnheader">Platform</span>
      <span role="columnheader">Published price shape</span>
      <span role="columnheader">AI models</span>
      <span role="columnheader">Modeled monthly</span>
      <span role="columnheader">Modeled per minute</span>
    </div>
    {
      rows.map((row) => (
        <div
          class="cost-row"
          role="row"
          data-platform-row={row.id}
          data-base={row.monthlyBase}
          data-included={row.includedMinutes}
          data-platform-rate={row.perMinute}
          data-model-rate={row.modelRate}
          data-carrier-rate={selectedCarrier.perMinute}
        >
          <span role="cell" data-label="Platform">
            <a data-comparison-source href={row.sourceUrl}>{row.name} ↗</a>
            <small data-lowest hidden>lowest in this model</small>
          </span>
          <span role="cell" data-label="Published price shape">{row.summary}</span>
          <span role="cell" data-label="AI models">
            {row.bundledModels ? "Included in the listed engine rate" : "Billed separately"}
          </span>
          <strong role="cell" data-label="Modeled monthly" data-monthly-cost>
            ${row.estimate.monthly.toLocaleString("en-US", { maximumFractionDigits: 0 })}
          </strong>
          <span role="cell" data-label="Modeled per minute" data-minute-cost>
            ${row.estimate.perMinute.toFixed(4)}
          </span>
        </div>
      ))
    }
  </div>
  <p class="table-note">
    Self-hosting is excluded from the ranking because it has no universal list price. Build a bill
    of materials for compute, networking, observability, capacity headroom, and on-call ownership.
    Start with the <a href="/open-source/">open-source framework directory</a>.
  </p>
</div>

<script>
  const model = document.querySelector<HTMLElement>("[data-cost-model]");
  const input = model?.querySelector<HTMLInputElement>("#comparison-minutes");
  const label = model?.querySelector<HTMLElement>("[data-volume-label]");
  const rows = Array.from(model?.querySelectorAll<HTMLElement>("[data-platform-row]") ?? []);

  const update = () => {
    if (!input || !label) return;
    const minutes = Math.min(10_000_000, Math.max(100, Number(input.value) || 100));
    label.textContent = `${minutes.toLocaleString("en-US")} minutes`;
    const totals = rows.map((row) => {
      const base = Number(row.dataset["base"]);
      const included = Number(row.dataset["included"]);
      const platformRate = Number(row.dataset["platformRate"]);
      const models = Number(row.dataset["modelRate"]);
      const carrier = Number(row.dataset["carrierRate"]);
      const total = base + Math.max(0, minutes - included) * platformRate + minutes * (models + carrier);
      row.querySelector<HTMLElement>("[data-monthly-cost]")!.textContent = total.toLocaleString(
        "en-US",
        { style: "currency", currency: "USD", maximumFractionDigits: 0 },
      );
      row.querySelector<HTMLElement>("[data-minute-cost]")!.textContent = `$${(total / minutes).toFixed(4)}`;
      return total;
    });
    const lowest = Math.min(...totals);
    rows.forEach((row, index) => {
      const marker = row.querySelector<HTMLElement>("[data-lowest]");
      if (marker) marker.hidden = totals[index] !== lowest;
    });
  };

  input?.addEventListener("input", update);
  update();
</script>

<style>
  .cost-model { border: 1px solid var(--border); background: var(--surface); }
  .cost-control { display: grid; grid-template-columns: minmax(0, 1fr) minmax(10rem, 0.35fr); gap: var(--s3) var(--s6); padding: var(--s6); }
  .cost-control label { align-self: center; color: var(--text); font-family: var(--font-mono); }
  .cost-control input { min-height: 44px; border: 1px solid var(--dim); border-radius: 4px; padding: var(--s2) var(--s3); background: var(--bg); color: var(--text); font: inherit; }
  .cost-control p { grid-column: 1 / -1; max-width: 72ch; margin: 0; color: var(--muted); font-size: 12px; }
  .cost-caption { display: flex; justify-content: space-between; gap: var(--s4); border-top: 1px solid var(--border); padding: var(--s3) var(--s6); color: var(--muted); font-family: var(--font-mono); font-size: 12px; }
  .cost-caption strong { color: var(--signal); font-weight: 500; }
  .cost-head, .cost-row { display: grid; grid-template-columns: 0.8fr 1.4fr 0.8fr 0.65fr 0.65fr; gap: var(--s4); align-items: start; border-top: 1px solid var(--border); padding: var(--s4) var(--s6); }
  .cost-head { color: var(--dim); font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; }
  .cost-row { background: var(--bg); color: var(--text-soft); font-size: 12px; }
  .cost-row a { color: var(--text); font-family: var(--font-mono); }
  .cost-row strong { color: var(--text); font-family: var(--font-mono); font-weight: 500; }
  .cost-row small { display: block; margin-top: var(--s2); color: var(--signal); font-size: 11px; }
  .cost-row small[hidden] { display: none; }
  .table-note { margin: 0; border-top: 1px solid var(--border); padding: var(--s4) var(--s6); color: var(--muted); font-size: 12px; }
  @media (max-width: 820px) {
    .cost-head { display: none; }
    .cost-table { display: grid; gap: 1px; background: var(--border); }
    .cost-row { grid-template-columns: repeat(2, minmax(0, 1fr)); border: 0; }
    .cost-row > span:nth-child(2), .cost-row > span:nth-child(3) { grid-column: 1 / -1; }
    .cost-row [role="cell"]::before { display: block; margin-bottom: var(--s2); color: var(--dim); content: attr(data-label); font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; }
  }
  @media (max-width: 600px) {
    .cost-control { grid-template-columns: 1fr; padding: var(--s5); }
    .cost-control p { grid-column: auto; }
    .cost-caption { align-items: flex-start; flex-direction: column; padding-inline: var(--s5); }
    .cost-row { padding: var(--s5); }
    .table-note { padding: var(--s5); }
  }
</style>
