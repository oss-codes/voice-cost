---
import {
  carriers,
  defaultRealtimeScenario,
  platforms,
  realtimeModels,
  recordingOptions,
} from "../data/pricing";

const realtimePlatforms = platforms.filter((platform) => !platform.bundledModels);
---

<form class="calc-shell realtime-calc" data-realtime-calculator autocomplete="off">
  <aside class="usage-panel">
    <h2>Realtime usage</h2>
    <label class="field">
      <span class="field-label">Monthly connected minutes</span>
      <input name="monthlyMinutes" type="number" min="1" max="10000000" step="100" value={defaultRealtimeScenario.monthlyMinutes} inputmode="numeric" />
      <span class="field-note">Total call duration, including both sides and silence.</span>
    </label>
    <label class="field">
      <span class="field-label">Average call length</span>
      <input name="averageCallMinutes" type="number" min="0.1" max="240" step="0.5" value={defaultRealtimeScenario.averageCallMinutes} inputmode="decimal" />
    </label>
    <label class="field">
      <span class="field-label">Caller talk share (%)</span>
      <input name="callerTalkShare" type="number" min="0" max="100" step="1" value={Math.round(defaultRealtimeScenario.callerTalkShare * 100)} inputmode="numeric" />
      <span class="field-note">Agent audio is the remaining share. Default: caller 55%, agent 45%.</span>
    </label>
    <div class="notice">
      <strong>why this matters</strong>
      <span>Realtime APIs charge incoming and generated audio differently. A connected minute is not one flat model minute.</span>
    </div>
    <p class="form-error" data-form-error role="alert" aria-live="assertive" hidden></p>
    <div class="calc-actions">
      <button class="button button-primary" type="button" data-copy>Copy estimate link</button>
      <button class="button" type="reset">Reset scenario</button>
    </div>
    <span class="sr-only" data-action-status role="status" aria-live="polite"></span>
  </aside>

  <div class="calc-content realtime-config">
    <div class="realtime-fields">
      <label class="field">
        <span class="field-label">Realtime speech model</span>
        <select name="realtimeModelId">
          {realtimeModels.map((model) => <option value={model.id} selected={model.id === defaultRealtimeScenario.realtimeModelId}>{model.name}</option>)}
        </select>
      </label>
      <label class="field">
        <span class="field-label">Platform / orchestration</span>
        <select name="platformId">
          {realtimePlatforms.map((platform) => <option value={platform.id} selected={platform.id === defaultRealtimeScenario.platformId}>{platform.name}</option>)}
        </select>
      </label>
      <label class="field">
        <span class="field-label">Carrier / transport</span>
        <select name="carrierId">
          {carriers.map((carrier) => <option value={carrier.id} selected={carrier.id === defaultRealtimeScenario.carrierId}>{carrier.name}</option>)}
        </select>
      </label>
      <label class="field">
        <span class="field-label">Recording</span>
        <select name="recordingId">
          {recordingOptions.map((recording) => <option value={recording.id} selected={recording.id === defaultRealtimeScenario.recordingId}>{recording.name}</option>)}
        </select>
      </label>
    </div>

    <div class="realtime-result" aria-live="polite">
      <div class="stack-total">
        <span class="data-label">Estimated monthly total</span>
        <strong data-output="monthly">$0</strong>
      </div>
      <div class="cost-meta"><span data-output="minute">$0/min</span> · <span data-output="call">$0/call</span></div>
      <ul class="breakdown">
        <li><span>platform</span><span data-output="platform">$0</span></li>
        <li><span>caller audio input</span><span data-output="input">$0</span></li>
        <li><span>agent audio output</span><span data-output="output">$0</span></li>
        <li><span>carrier</span><span data-output="carrier">$0</span></li>
        <li><span>recording</span><span data-output="recording">$0</span></li>
      </ul>
    </div>

    <div class="model-assumption">
      <span class="data-label">Model assumption</span>
      <p data-model-detail></p>
      <a class="source-badge" data-model-source href={realtimeModels[0].sourceUrl}>official model pricing ↗</a>
    </div>
  </div>
</form>

<script>
  import { calculateRealtimeVoice } from "../lib/calculate";
  import { RealtimeScenarioSchema, realtimeModels } from "../data/pricing";

  const form = document.querySelector("[data-realtime-calculator]");
  const money = new Intl.NumberFormat("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 2 });
  const preciseMoney = new Intl.NumberFormat("en-US", { style: "currency", currency: "USD", minimumFractionDigits: 3, maximumFractionDigits: 4 });

  if (form instanceof HTMLFormElement) {
    const value = (name: string) => {
      const field = form.elements.namedItem(name);
      return field instanceof HTMLInputElement || field instanceof HTMLSelectElement ? field.value : "";
    };
    const setText = (key: string, next: string) => {
      const element = form.querySelector(`[data-output="${key}"]`);
      if (element instanceof HTMLElement) element.textContent = next;
    };
    const resultPanel = form.querySelector(".realtime-result");
    const formError = form.querySelector("[data-form-error]");
    const setInvalid = () => {
      form.dataset["invalid"] = "true";
      if (resultPanel instanceof HTMLElement) resultPanel.dataset["invalid"] = "true";
      if (formError instanceof HTMLElement) {
        formError.textContent =
          "Enter monthly connected minutes from 1 to 10,000,000, a call length from 0.1 to 240 minutes, and a caller talk share from 0% to 100%.";
        formError.hidden = false;
      }
      for (const field of form.querySelectorAll("input, select")) {
        if (field instanceof HTMLInputElement || field instanceof HTMLSelectElement) {
          field.setAttribute("aria-invalid", String(!field.checkValidity()));
        }
      }
      for (const key of ["monthly", "minute", "call", "platform", "input", "output", "carrier", "recording"]) {
        setText(key, "Unavailable");
      }
    };
    const clearInvalid = () => {
      delete form.dataset["invalid"];
      if (resultPanel instanceof HTMLElement) delete resultPanel.dataset["invalid"];
      if (formError instanceof HTMLElement) {
        formError.textContent = "";
        formError.hidden = true;
      }
      for (const field of form.querySelectorAll("[aria-invalid]")) {
        field.removeAttribute("aria-invalid");
      }
    };

    const setInitialState = () => {
      const params = new URLSearchParams(window.location.search);
      for (const name of ["monthlyMinutes", "averageCallMinutes", "callerTalkShare", "platformId", "realtimeModelId", "carrierId", "recordingId"]) {
        const candidate = params.get(name);
        const field = form.elements.namedItem(name);
        if (candidate === null || !(field instanceof HTMLInputElement || field instanceof HTMLSelectElement)) continue;
        if (field instanceof HTMLSelectElement && !Array.from(field.options).some((option) => option.value === candidate)) continue;
        field.value = candidate;
      }
    };

    const render = () => {
      const parsed = RealtimeScenarioSchema.safeParse({
        monthlyMinutes: Number(value("monthlyMinutes")),
        averageCallMinutes: Number(value("averageCallMinutes")),
        callerTalkShare: Number(value("callerTalkShare")) / 100,
        platformId: value("platformId"),
        realtimeModelId: value("realtimeModelId"),
        carrierId: value("carrierId"),
        recordingId: value("recordingId"),
      });
      if (!parsed.success) {
        setInvalid();
        return;
      }

      clearInvalid();
      const estimate = calculateRealtimeVoice(parsed.data);
      const model = realtimeModels.find((candidate) => candidate.id === parsed.data.realtimeModelId);
      setText("monthly", money.format(estimate.monthly));
      setText("minute", `${preciseMoney.format(estimate.perMinute)}/connected min`);
      setText("call", `${money.format(estimate.perCall)}/call`);
      setText("platform", money.format(estimate.breakdown.platform));
      setText("input", `${money.format(estimate.breakdown.realtimeInput)} · ${estimate.inputAudioMinutes.toLocaleString("en-US")} min`);
      setText("output", `${money.format(estimate.breakdown.realtimeOutput)} · ${estimate.outputAudioMinutes.toLocaleString("en-US")} min`);
      setText("carrier", money.format(estimate.breakdown.carrier));
      setText("recording", money.format(estimate.breakdown.recording));

      const detail = form.querySelector("[data-model-detail]");
      const source = form.querySelector("[data-model-source]");
      if (model && detail instanceof HTMLElement) detail.textContent = model.detail;
      if (model && source instanceof HTMLAnchorElement) source.href = model.sourceUrl;

      const params = new URLSearchParams();
      for (const name of ["monthlyMinutes", "averageCallMinutes", "callerTalkShare", "platformId", "realtimeModelId", "carrierId", "recordingId"]) {
        const candidate = value(name);
        params.set(
          name,
          name === "callerTalkShare" ? String(Number.parseFloat(candidate)) : candidate,
        );
      }
      window.history.replaceState(null, "", `${window.location.pathname}?${params.toString()}`);
    };

    form.addEventListener("input", render);
    form.addEventListener("change", render);
    form.addEventListener("reset", () => window.setTimeout(render));

    const copyButton = form.querySelector("[data-copy]");
    const actionStatus = form.querySelector("[data-action-status]");
    if (copyButton instanceof HTMLButtonElement) {
      copyButton.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(window.location.href);
          copyButton.textContent = "Link copied";
          if (actionStatus instanceof HTMLElement) {
            actionStatus.textContent = "Estimate link copied to clipboard.";
          }
          window.setTimeout(() => {
            copyButton.textContent = "Copy estimate link";
          }, 1_500);
        } catch {
          copyButton.textContent = "Copy blocked";
          if (actionStatus instanceof HTMLElement) {
            actionStatus.textContent = "Clipboard access was blocked. Copy the browser address.";
          }
        }
      });
    }
    setInitialState();
    render();
  }
</script>
