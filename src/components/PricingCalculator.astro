---
import {
  carriers,
  defaultScenario,
  llmModels,
  platforms,
  recordingOptions,
  sttModels,
  ttsModels,
  VERIFIED_AT,
} from "../data/pricing";

const stacks = [
  { key: "a", platformId: "vapi", label: "Stack A" },
  { key: "b", platformId: "retell", label: "Stack B" },
  { key: "c", platformId: "bland-start", label: "Stack C" },
] as const;
---

<form class="calc-shell" data-calculator autocomplete="off">
  <aside class="usage-panel">
    <h2>Usage profile</h2>
    <div class="scenario-presets" aria-label="Usage presets">
      <button type="button" data-preset="1000">Prototype 1k</button>
      <button type="button" data-preset="10000">Pilot 10k</button>
      <button type="button" data-preset="100000">Scale 100k</button>
    </div>
    <label class="field">
      <span class="field-label">Monthly call minutes</span>
      <input
        name="monthlyMinutes"
        type="number"
        min="1"
        max="10000000"
        step="100"
        value={defaultScenario.monthlyMinutes}
        inputmode="numeric"
      />
      <span class="field-note">Connected minutes across all calls.</span>
    </label>
    <label class="field">
      <span class="field-label">Average call length</span>
      <input
        name="averageCallMinutes"
        type="number"
        min="0.1"
        max="240"
        step="0.5"
        value={defaultScenario.averageCallMinutes}
        inputmode="decimal"
      />
      <span class="field-note">Used to estimate cost per completed call.</span>
    </label>
    <div class="notice">
      <strong>snapshot</strong>
      <span>USD pre-tax. Public list prices, verified {VERIFIED_AT}. Enterprise discounts excluded.</span>
    </div>
    <p class="form-error" data-form-error role="alert" aria-live="assertive" hidden></p>
    <div class="calc-actions">
      <button class="button button-primary" type="button" data-copy>Copy estimate link</button>
      <button class="button" type="button" data-export>Export CSV</button>
      <button class="button" type="reset" data-reset>Reset scenario</button>
      <a class="button" href="/methodology/">inspect formulas</a>
    </div>
    <span class="sr-only" data-action-status role="status" aria-live="polite"></span>
  </aside>

  <div class="calc-content">
    <div class="stack-grid">
      {
        stacks.map((stack) => (
          <fieldset class="stack-panel" data-stack={stack.key}>
            <legend class="sr-only">{stack.label}</legend>
            <h2>{stack.label}</h2>
            <div class="stack-status" data-output={`${stack.key}-status`} aria-live="polite" />

            <label class="field">
              <span class="field-label">Platform</span>
              <select name={`${stack.key}-platformId`}>
                {platforms.map((platform) => (
                  <option value={platform.id} selected={platform.id === stack.platformId}>
                    {platform.name}
                  </option>
                ))}
              </select>
            </label>

            <label class="field">
              <span class="field-label">Speech to text</span>
              <select name={`${stack.key}-sttId`} data-model-field>
                {sttModels.map((model) => (
                  <option value={model.id} selected={model.id === defaultScenario.sttId}>
                    {model.name}
                  </option>
                ))}
              </select>
            </label>

            <label class="field">
              <span class="field-label">Language model</span>
              <select name={`${stack.key}-llmId`} data-model-field>
                {llmModels.map((model) => (
                  <option value={model.id} selected={model.id === defaultScenario.llmId}>
                    {model.name}
                  </option>
                ))}
              </select>
            </label>

            <label class="field">
              <span class="field-label">Text to speech</span>
              <select name={`${stack.key}-ttsId`} data-model-field>
                {ttsModels.map((model) => (
                  <option value={model.id} selected={model.id === defaultScenario.ttsId}>
                    {model.name}
                  </option>
                ))}
              </select>
            </label>

            <label class="field">
              <span class="field-label">Carrier / transport</span>
              <select name={`${stack.key}-carrierId`}>
                {carriers.map((carrier) => (
                  <option value={carrier.id} selected={carrier.id === defaultScenario.carrierId}>
                    {carrier.name}
                  </option>
                ))}
              </select>
            </label>

            <label class="field">
              <span class="field-label">Recording</span>
              <select name={`${stack.key}-recordingId`}>
                {recordingOptions.map((recording) => (
                  <option
                    value={recording.id}
                    selected={recording.id === defaultScenario.recordingId}
                  >
                    {recording.name}
                  </option>
                ))}
              </select>
            </label>

            <div class="stack-result">
              <div class="stack-total">
                <span class="data-label">Monthly</span>
                <strong data-output={`${stack.key}-monthly`}>$0</strong>
              </div>
              <div class="cost-meta">
                <span data-output={`${stack.key}-minute`}>$0/min</span>
                ·
                <span data-output={`${stack.key}-call`}>$0/call</span>
              </div>
              <ul class="breakdown">
                <li><span>platform</span><span data-output={`${stack.key}-platform`}>$0</span></li>
                <li><span>STT</span><span data-output={`${stack.key}-stt`}>$0</span></li>
                <li><span>LLM</span><span data-output={`${stack.key}-llm`}>$0</span></li>
                <li><span>TTS</span><span data-output={`${stack.key}-tts`}>$0</span></li>
                <li><span>carrier</span><span data-output={`${stack.key}-carrier`}>$0</span></li>
                <li><span>recording</span><span data-output={`${stack.key}-recording`}>$0</span></li>
              </ul>
            </div>
          </fieldset>
        ))
      }
    </div>

    <div class="cost-bars" aria-label="Monthly cost comparison">
      {
        stacks.map((stack) => (
          <div class="cost-bar-row" data-bar={stack.key}>
            <span data-output={`${stack.key}-name`}>{stack.label}</span>
            <div class="bar-track" aria-hidden="true"><div class="bar-fill" /></div>
            <strong data-output={`${stack.key}-bar-value`}>$0</strong>
          </div>
        ))
      }
    </div>
  </div>
</form>

<script>
  import { z } from "zod";

  import { calculateStack } from "../lib/calculate";
  import { platforms, ScenarioSchema } from "../data/pricing";

  const form = document.querySelector("[data-calculator]");
  const stackKeys = ["a", "b", "c"] as const;
  const money = new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 2,
  });
  const preciseMoney = new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
    minimumFractionDigits: 3,
    maximumFractionDigits: 4,
  });
  const MinutesSchema = z.coerce.number().int().min(1).max(10_000_000);
  type Estimate = ReturnType<typeof calculateStack>;
  let latestEstimates: Array<{ key: (typeof stackKeys)[number]; result: Estimate }> = [];

  if (form instanceof HTMLFormElement) {
    const numberValue = (name: string) => {
      const field = form.elements.namedItem(name);
      return field instanceof HTMLInputElement ? Number(field.value) : Number.NaN;
    };

    const selectValue = (name: string) => {
      const field = form.elements.namedItem(name);
      return field instanceof HTMLSelectElement ? field.value : "";
    };

    const setText = (key: string, value: string) => {
      const element = form.querySelector(`[data-output="${key}"]`);
      if (element instanceof HTMLElement) {
        element.textContent = value;
      }
    };

    const setFieldValue = (name: string, value: string) => {
      const field = form.elements.namedItem(name);
      if (field instanceof HTMLInputElement) {
        field.value = value;
        return;
      }
      if (
        field instanceof HTMLSelectElement &&
        Array.from(field.options).some((option) => option.value === value)
      ) {
        field.value = value;
      }
    };

    const formError = form.querySelector("[data-form-error]");
    const setInvalid = (message: string) => {
      form.dataset["invalid"] = "true";
      if (formError instanceof HTMLElement) {
        formError.textContent = message;
        formError.hidden = false;
      }
      for (const field of form.querySelectorAll("input, select")) {
        if (field instanceof HTMLInputElement || field instanceof HTMLSelectElement) {
          field.setAttribute("aria-invalid", String(!field.checkValidity()));
        }
      }
      for (const key of stackKeys) {
        for (const output of ["monthly", "minute", "call", "bar-value"]) {
          setText(`${key}-${output}`, "Unavailable");
        }
        setText(`${key}-status`, "check usage input");
        const panel = form.querySelector(`[data-stack="${key}"]`);
        const row = form.querySelector(`[data-bar="${key}"]`);
        const fill = row?.querySelector(".bar-fill");
        if (panel instanceof HTMLElement) delete panel.dataset["best"];
        if (row instanceof HTMLElement) delete row.dataset["best"];
        if (fill instanceof HTMLElement) fill.style.setProperty("--bar-width", "0%");
      }
    };

    const clearInvalid = () => {
      delete form.dataset["invalid"];
      if (formError instanceof HTMLElement) {
        formError.textContent = "";
        formError.hidden = true;
      }
      for (const field of form.querySelectorAll("[aria-invalid]")) {
        field.removeAttribute("aria-invalid");
      }
    };

    const scenarioFor = (key: (typeof stackKeys)[number]) =>
      ScenarioSchema.safeParse({
        monthlyMinutes: numberValue("monthlyMinutes"),
        averageCallMinutes: numberValue("averageCallMinutes"),
        platformId: selectValue(`${key}-platformId`),
        sttId: selectValue(`${key}-sttId`),
        llmId: selectValue(`${key}-llmId`),
        ttsId: selectValue(`${key}-ttsId`),
        carrierId: selectValue(`${key}-carrierId`),
        recordingId: selectValue(`${key}-recordingId`),
      });

    const setInitialState = () => {
      const params = new URLSearchParams(window.location.search);
      const minutes = MinutesSchema.safeParse(
        params.get("monthlyMinutes") ?? params.get("minutes"),
      );
      const minutesField = form.elements.namedItem("monthlyMinutes");
      if (minutes.success && minutesField instanceof HTMLInputElement) {
        minutesField.value = String(minutes.data);
      }

      const averageCallMinutes = z.coerce
        .number()
        .min(0.1)
        .max(240)
        .safeParse(params.get("averageCallMinutes"));
      if (averageCallMinutes.success) {
        setFieldValue("averageCallMinutes", String(averageCallMinutes.data));
      }

      for (const key of stackKeys) {
        for (const suffix of [
          "platformId",
          "sttId",
          "llmId",
          "ttsId",
          "carrierId",
          "recordingId",
        ]) {
          const name = `${key}-${suffix}`;
          const candidate =
            params.get(name) ?? (suffix === "platformId" ? params.get(key) : null);
          if (candidate !== null) setFieldValue(name, candidate);
        }
      }
    };

    const render = () => {
      const estimates = stackKeys.flatMap((key) => {
        const parsed = scenarioFor(key);
        if (!parsed.success) {
          return [];
        }

        const platform = platforms.find((item) => item.id === parsed.data.platformId);
        if (platform === undefined) {
          setText(`${key}-status`, "unknown platform");
          return [];
        }

        const result = calculateStack(parsed.data);
        const panel = form.querySelector(`[data-stack="${key}"]`);
        if (panel instanceof HTMLElement) {
          for (const field of panel.querySelectorAll("[data-model-field]")) {
            if (field instanceof HTMLSelectElement) {
              field.disabled = platform.bundledModels;
            }
          }
        }

        setText(`${key}-status`, platform.bundledModels ? "models included" : "components itemized");
        setText(`${key}-name`, platform.name);
        setText(`${key}-monthly`, money.format(result.monthly));
        setText(`${key}-minute`, `${preciseMoney.format(result.perMinute)}/min`);
        setText(`${key}-call`, `${money.format(result.perCall)}/call`);
        setText(`${key}-platform`, money.format(result.breakdown.platform));
        setText(`${key}-stt`, money.format(result.breakdown.stt));
        setText(`${key}-llm`, money.format(result.breakdown.llm));
        setText(`${key}-tts`, money.format(result.breakdown.tts));
        setText(`${key}-carrier`, money.format(result.breakdown.carrier));
        setText(`${key}-recording`, money.format(result.breakdown.recording));
        setText(`${key}-bar-value`, money.format(result.monthly));

        return [{ key, result }];
      });

      if (estimates.length !== stackKeys.length) {
        setInvalid(
          "Enter monthly call minutes from 1 to 10,000,000 and an average call length from 0.1 to 240 minutes.",
        );
        return;
      }

      clearInvalid();
      latestEstimates = estimates;
      const monthlyValues = estimates.map((item) => item.result.monthly);
      const maxMonthly = Math.max(...monthlyValues);
      const minMonthly = Math.min(...monthlyValues);

      for (const estimate of estimates) {
        const isBest = estimate.result.monthly === minMonthly;
        const panel = form.querySelector(`[data-stack="${estimate.key}"]`);
        const row = form.querySelector(`[data-bar="${estimate.key}"]`);
        const fill = row?.querySelector(".bar-fill");
        if (panel instanceof HTMLElement) panel.dataset["best"] = String(isBest);
        if (row instanceof HTMLElement) row.dataset["best"] = String(isBest);
        if (fill instanceof HTMLElement) {
          fill.style.setProperty(
            "--bar-width",
            `${Math.max(4, (estimate.result.monthly / maxMonthly) * 100)}%`,
          );
        }
      }

      const params = new URLSearchParams();
      for (const name of ["monthlyMinutes", "averageCallMinutes"]) {
        params.set(name, String(numberValue(name)));
      }
      for (const key of stackKeys) {
        for (const suffix of [
          "platformId",
          "sttId",
          "llmId",
          "ttsId",
          "carrierId",
          "recordingId",
        ]) {
          const name = `${key}-${suffix}`;
          params.set(name, selectValue(name));
        }
      }
      window.history.replaceState(null, "", `${window.location.pathname}?${params.toString()}`);
    };

    form.addEventListener("input", render);
    form.addEventListener("change", render);

    const copyButton = form.querySelector("[data-copy]");
    const actionStatus = form.querySelector("[data-action-status]");
    const reportAction = (message: string) => {
      if (actionStatus instanceof HTMLElement) actionStatus.textContent = message;
    };
    if (copyButton instanceof HTMLButtonElement) {
      copyButton.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(window.location.href);
          copyButton.textContent = "Link copied";
          reportAction("Estimate link copied to clipboard.");
          window.setTimeout(() => {
            copyButton.textContent = "Copy estimate link";
          }, 1_500);
        } catch (error) {
          if (error instanceof DOMException) {
            copyButton.textContent = "Copy blocked";
            reportAction("Clipboard access was blocked. Copy the address from your browser.");
            return;
          }
          throw error;
        }
      });
    }

    for (const preset of form.querySelectorAll("[data-preset]")) {
      if (!(preset instanceof HTMLButtonElement)) continue;
      preset.addEventListener("click", () => {
        const minutes = preset.dataset["preset"];
        if (minutes === undefined) return;
        setFieldValue("monthlyMinutes", minutes);
        render();
        reportAction(`${preset.textContent?.trim() ?? "Usage"} preset applied.`);
      });
    }

    const exportButton = form.querySelector("[data-export]");
    if (exportButton instanceof HTMLButtonElement) {
      exportButton.addEventListener("click", () => {
        if (latestEstimates.length !== stackKeys.length) {
          reportAction("Fix the usage inputs before exporting.");
          return;
        }
        const header = [
          "stack",
          "platform",
          "monthly",
          "per_minute",
          "per_call",
          "stt",
          "llm",
          "tts",
          "carrier",
          "recording",
        ];
        const rows = latestEstimates.map(({ key, result }) => [
          key.toUpperCase(),
          selectValue(`${key}-platformId`),
          result.monthly,
          result.perMinute,
          result.perCall,
          result.breakdown.stt,
          result.breakdown.llm,
          result.breakdown.tts,
          result.breakdown.carrier,
          result.breakdown.recording,
        ]);
        const csv = [header, ...rows]
          .map((row) => row.map((cell) => JSON.stringify(String(cell))).join(","))
          .join("\n");
        const url = URL.createObjectURL(new Blob([csv], { type: "text/csv;charset=utf-8" }));
        const link = document.createElement("a");
        link.href = url;
        link.download = "voice-ai-cost-comparison.csv";
        link.click();
        URL.revokeObjectURL(url);
        reportAction("CSV export downloaded.");
      });
    }

    form.addEventListener("reset", () => {
      window.setTimeout(() => {
        render();
        reportAction("Scenario reset to defaults.");
      });
    });

    setInitialState();
    render();
  }
</script>
