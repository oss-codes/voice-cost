---
type Props = {
  readonly eyebrow: string;
  readonly title: string;
  readonly description: string;
  readonly parent?: { readonly href: string; readonly label: string };
};

const { eyebrow, title, description, parent } = Astro.props;
const parentIsCurrentPage = parent?.href === Astro.url.pathname;
---

<header class="page-hero">
  {
    parent && (
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">home</a>
        <span aria-hidden="true"> / </span>
        {!parentIsCurrentPage && (
          <>
            <a href={parent.href}>{parent.label}</a>
            <span aria-hidden="true"> / </span>
          </>
        )}
        <span aria-current="page">{title}</span>
      </nav>
    )
  }
  <span class="eyebrow page-eyebrow">{eyebrow}</span>
  <h1>{title}</h1>
  <p class="lead">{description}</p>
  <slot />
</header>
